{% extends "base.twig" %}

{% block content %}
	<div class="page-wrap single-twig push-nav">
    <div class="def-x py-20">
      <div class="svg-section">
        <div class="svg-wrapper"></div>

        <section class="title svg-group pt-20 def-x-big lg:def-x-half">
          <h1 class="forma-h1 text-center {% if post.get_field('subtitle') %}mb-12{% else %}mb-20{% endif %}">{{ post.title }}</h1>

          {% if post.get_field('subtitle') %}
            <h2 class="forma-h2 text-center mb-20">{{ post.get_field('subtitle') }}</h2>
          {% endif %}
        </section>

				<section class="svg-group py-20 def-x max-default mx-auto">
					<div class="mb-16">
            {% 
              include 'partial/image-sizer.twig' with {
                'classes': 'mb-def-1/2',
                'image': Image(post.get_field('main_image')),
                'loadBgClass': 'bg-grey',
                'ratioPaddingVal': 60
              }
            %}

            {% if post.get_field('main_image').caption %}
              <p class="forma-caption">{{ post.get_field('main_image').caption }}</p>
            {% endif %}
          </div>

          <div class="max-default mx-auto mb-16">
            <div class="info mb-16">
              {% if post.get_field('author') %}
                <p class="forma-body">{{ post.author }}</p>
              {% endif %}
              <p class="forma-body">{{ post.date|date('m.d.y') }}</p>
            </div>
            
            <div class="content forma-body has-blog-styles overflow-x-hidden">{{ post.content }}</div>
          </div>

          <div class="flex flex-wrap justify-center clear-both">
            <div class="w-full lg:w-1/2 lg:px-def-1/2 mb-def-1/2 lg:mb-def">
              <a 
                href="/news" 
                class="def-button w-full neon block"
                aria-label="Go to news."
              >Back to News</a>
            </div>

            <div class="w-full lg:w-1/2 lg:px-def-1/2 mb-def-1/2 lg:mb-def">
              {% 
                include 'partial/def-button.twig' with {
                  'href': next_link.link,
                  'classes': 'w-full neon block',
                  'label': "Go to " ~ next_link.title,
                  'title': "Next: " ~ next_link.title
                }
              %}
            </div>
          </div>
				</section>

        {% if post.get_field('related_links') %}
          {% 
            include 'partial/related-items.twig' with {
              'items': post.get_field('related_links'),
              'color': 'neon'
            }
          %}
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
