{% extends "base.twig" %}

{% block content %}
	<div class="page-wrap magazine push-nav">
    <h1 class="wcag-hidden">Magazine</h1>

    <div class="def-x py-20">
      <div class="svg-section">
        <div class="svg-wrapper"></div>

        <section 
          class="title svg-group py-20 def-x-big lg:def-x-half"
          aria-label="Title section"
        >
          <h1 class="forma-huge text-center">SPHERE<sup>{{ "now"|date("m.d.y") }}</sup></h1>
          {% if post.get_field('subtitle') %}
            <h2 class="forma-h2 text-center">{{ post.get_field('subtitle') }}</h2>
          {% endif %}
        </section>
        
        {% if post.get_field('featured_video') %}
          <section 
            class="featured-video svg-group py-20 def-x-big lg:def-x"
            aria-label="Featured Video section"
          >
            <div class="tags mb-4">
              <span
                class="def-button-sm neon inline-block mr-4"
              >Magazine</span>
            </div>

            <div class="mb-16 w-full block">
              <div class="default-video mb-4" data-yt-id="{{ post.get_field('featured_video').youtube_id }}">
                <div class="sizer relative w-full">
                  <div class="inner absolute top-0 left-0 w-full h-full"></div>

                  {% if post.get_field('featured_video').video_poster %}
                    <div class="overlay absolute top-0 left-0 w-full h-full z-10 flex justify-center items-center">
                      <img class="object-center object-cover w-full h-full" src="{{ Image(post.get_field('featured_video').video_poster).src }}" alt="{{ post.get_field('featured_video').video_poster }}">

                      <button 
                        class="play-video neon flex justify-center items-center rounded-xl w-24 h-24 forma-body absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2"
                        aria-label="Play video."
                      >
                        {% include 'partial/svg/play.twig' %}
                      </button>
                    </div>
                  {% endif %}
                </div>
              </div>

              <a href="{{ post.get_field('featured_video').link }}" class="forma-body lg:hover:underline">{{ post.get_field('featured_video').title }}</a>
            </div>

            <div class="flex flex-wrap justify-center clear-both mt-20">
              <div class="w-full lg:w-1/2 lg:px-def-1/2 mb-def-1/2 lg:mb-def">
                <a 
                  href="/video-series" 
                  class="def-button w-full neon block"
                  aria-label="Go to Video Series."
                >See all Video Series</a>
              </div>
            </div>
          </section>
        {% endif %}

        {% if categories_array|length > 0 %}
          {% for item in categories_array %}
            <section 
              id="{{ item.slug }}"
              class="category svg-group py-20 def-x-big lg:def-x-half scroll-to-section"
            >
              <h2 class="forma-h2 text-center mb-20">{{ item.title }}</h2>

              {% for post in item.posts %}
                {% 
                  include 'partial/post-item.twig' with {
                    'width': post.get_field('card_width'),
                    'item': post,
                    'buttonColor': 'neon'
                  }
                %}         
              {% endfor %}

              <div class="flex flex-wrap justify-center clear-both">
                <div class="w-full lg:w-1/2 lg:px-def-1/2 mb-def-1/2 lg:mb-def">
                  <a 
                    href="/news/category/{{ item.slug }}" 
                    class="def-button w-full neon block"
                    aria-label="Go to {{ item.cat_title }} category."
                  >{{ item.cat_title }}</a>
                </div>
              </div>
            </section>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
