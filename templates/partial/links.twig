<div class="flex flex-wrap justify-center clear-both {{ classes }}">
  {% for item in links %}
    {% set class = 'w-full neon' %}
    {% set linksLength = links|length %}
    {% set marginClass = 'mb-0' %}

    {% if linksLength == 2 %}
      {% set marginClass = 'mb-def-1/2 lg:mb-0' %}
    {% elseif linksLength > 2 %}
      {% set marginClass = 'mb-def-1/2 lg:mb-def' %}
    {% endif %}

    {% if color %}
      {% set class = 'w-full ' ~ color %}
    {% endif %}

    <div class="w-full lg:w-1/2 lg:px-def-1/2 {{ marginClass }}">
      {% 
        include 'partial/def-button.twig' with {
          'href': item.link.url,
          'classes': class,
          'label': "Go to " ~ item.link.title,
          'title': item.link.title
        }
      %}
    </div>
  {% endfor %}
</div>